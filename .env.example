# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agentworld

# Optional: Redis for caching/pubsub
REDIS_URL=redis://localhost:6379/0

# LLM API Keys (for real agent integration)
ANTHROPIC_API_KEY=your_claude_key_here
OPENAI_API_KEY=your_openai_key_here

# App Config
APP_ENV=development
LOG_LEVEL=info
