# AgentVerse Environment Configuration
# Copy to .env and fill in your values

# ============================================
# Core Services
# ============================================

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/agentworld
POSTGRES_USER=agentverse
POSTGRES_PASSWORD=change_me_in_production

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=redis_password

# JWT Authentication
JWT_SECRET=your-256-bit-secret-here

# ============================================
# LLM API Keys
# ============================================

ANTHROPIC_API_KEY=your_claude_key_here
OPENAI_API_KEY=your_openai_key_here

# ============================================
# ChatDev Money Integration
# ============================================

CHATDEV_API_URL=http://localhost:8000
USE_REAL_CHATDEV=false

# ============================================
# Camofox Browser (Phase 4)
# ============================================

# Optional: Proxy configuration for stealth browsing
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# Optional: API key for cookie import (disabled if not set)
CAMOFOX_API_KEY=

# ============================================
# Multica Agent Orchestration (Phase 4)
# ============================================

MULTICA_POSTGRES_USER=multica
MULTICA_POSTGRES_PASSWORD=change_me_in_production
MULTICA_JWT_SECRET=multica_jwt_secret

# ============================================
# Monitoring & Alerting
# ============================================

GRAFANA_PASSWORD=admin
SLACK_WEBHOOK_URL=

# ============================================
# Docker/Deployment
# ============================================

REGISTRY=ghcr.io/casss20
IMAGE_TAG=latest

# ============================================
# App Config
# ============================================

APP_ENV=development
LOG_LEVEL=info
