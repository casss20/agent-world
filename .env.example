# Agent World — Environment Configuration
# Copy this file to .env and fill in your values

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost/agentworld

# ── LLM Provider ────────────────────────────────────────────────────────────
# Choose one: ollama | openai | anthropic

# Option A: Ollama (local, FREE — recommended to start)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_API_KEY=ollama
LLM_BASE_URL=http://localhost:11434/v1

# Option B: OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...

# Option C: Anthropic
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-20241022
# LLM_API_KEY=sk-ant-...

# ── Agent Executor ───────────────────────────────────────────────────────────
EXECUTOR_POLL_INTERVAL=3      # seconds between task polls
EXECUTOR_LEASE_TTL=120        # seconds before a claimed task expires

# ── File Workspace ───────────────────────────────────────────────────────────
WORKSPACE_ROOT=./workspace    # where agents store files
