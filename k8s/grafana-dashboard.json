{
  "dashboard": {
    "id": null,
    "title": "Agent World - Production Dashboard",
    "tags": ["agent-world", "production"],
    "timezone": "UTC",
    "schemaVersion": 36,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(rate(agentworld_requests_total[5m]))",
            "legendFormat": "Requests/sec"
          }
        ],
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Error Rate",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(rate(agentworld_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(agentworld_requests_total[5m]))",
            "legendFormat": "Error %"
          }
        ],
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 0.01},
                {"color": "red", "value": 0.05}
              ]
            },
            "unit": "percentunit"
          }
        }
      },
      {
        "id": 3,
        "title": "P95 Latency",
        "type": "stat",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(agentworld_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P95"
          }
        ],
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "id": 4,
        "title": "Active Agents",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(agentworld_agents_by_status{status=\"online\"})",
            "legendFormat": "Online"
          },
          {
            "expr": "sum(agentworld_agents_by_status{status=\"busy\"})",
            "legendFormat": "Busy"
          }
        ],
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0}
      },
      {
        "id": 5,
        "title": "Task Queue Depth",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(agentworld_task_queue_depth{status=\"pending\"})",
            "legendFormat": "Pending"
          },
          {
            "expr": "sum(agentworld_task_queue_depth{status=\"failed\"})",
            "legendFormat": "Failed (DLQ)"
          }
        ],
        "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Failed (DLQ)"},
              "properties": [
                {
                  "id": "thresholds",
                  "value": {
                    "steps": [
                      {"color": "green", "value": 0},
                      {"color": "yellow", "value": 50},
                      {"color": "red", "value": 100}
                    ]
                  }
                }
              ]
            }
          ]
        }
      },
      {
        "id": 6,
        "title": "WebSocket Connections",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(agentworld_websocket_connections)",
            "legendFormat": "Connections"
          }
        ],
        "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0}
      },
      {
        "id": 7,
        "title": "Request Latency Over Time",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(agentworld_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(agentworld_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(agentworld_request_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "P99"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "yaxes": [{"format": "s"}]
      },
      {
        "id": 8,
        "title": "Request Rate by Endpoint",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(agentworld_requests_total[5m])) by (endpoint)",
            "legendFormat": "{{ endpoint }}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
      },
      {
        "id": 9,
        "title": "Agent Status Distribution",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum(agentworld_agents_by_status) by (status)",
            "legendFormat": "{{ status }}"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 12}
      },
      {
        "id": 10,
        "title": "Task Processing Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(agentworld_agent_tasks_completed_total[5m]))",
            "legendFormat": "Completed/sec"
          },
          {
            "expr": "sum(rate(agentworld_agent_tasks_failed_total[5m]))",
            "legendFormat": "Failed/sec"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 6, "y": 12}
      },
      {
        "id": 11,
        "title": "Task Processing Time",
        "type": "heatmap",
        "targets": [
          {
            "expr": "sum(rate(agentworld_task_processing_seconds_bucket[5m])) by (le)",
            "legendFormat": "{{ le }}"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 12},
        "heatmap": {}
      },
      {
        "id": 12,
        "title": "Room Activity",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(agentworld_room_members) by (room_id)",
            "legendFormat": "Room {{ room_id }}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20}
      },
      {
        "id": 13,
        "title": "Error Rate by Type",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(agentworld_agent_tasks_failed_total[5m])) by (failure_reason)",
            "legendFormat": "{{ failure_reason }}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20}
      },
      {
        "id": 14,
        "title": "DLQ Tasks by Error Type",
        "type": "table",
        "targets": [
          {
            "expr": "sum(agentworld_task_queue_depth{status=\"failed\"}) by (task_type, error_type)",
            "format": "table",
            "instant": true
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 28},
        "transformations": [
          {
            "id": "organize",
            "options": {
              "indexByName": {"task_type": 0, "error_type": 1, "Value": 2},
              "renameByName": {"Value": "Count"}
            }
          }
        ]
      },
      {
        "id": 15,
        "title": "Pod CPU Usage",
        "type": "graph",
        "datasource": "prometheus",
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"agent-world\", pod=~\"agent-world-backend-.*\"}[5m])) by (pod)",
            "legendFormat": "{{ pod }}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 36}
      },
      {
        "id": 16,
        "title": "Pod Memory Usage",
        "type": "graph",
        "datasource": "prometheus",
        "targets": [
          {
            "expr": "sum(container_memory_working_set_bytes{namespace=\"agent-world\", pod=~\"agent-world-backend-.*\"}) by (pod)",
            "legendFormat": "{{ pod }}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 36},
        "yaxes": [{"format": "bytes"}]
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "templating": {
      "list": [
        {
          "name": "namespace",
          "type": "constant",
          "current": {"value": "agent-world", "text": "agent-world"}
        }
      ]
    }
  }
}
