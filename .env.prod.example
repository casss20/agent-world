# Production Environment Configuration
# Copy to .env and fill in values before deployment

# Database
DB_PASSWORD=change_me_to_strong_password_32_chars
DATABASE_URL=postgresql://postgres:${DB_PASSWORD}@postgres:5432/agent_world

# JWT Security
JWT_SECRET=change_me_to_random_64_char_string

# OpenAI
OPENAI_API_KEY=sk-...

# Webhook Security
WEBHOOK_SECRET=change_me_to_random_32_char_string

# Redis
REDIS_URL=redis://redis:6379/0

# Grafana
GRAFANA_PASSWORD=change_me_to_admin_password

# Environment
ENVIRONMENT=production
LOG_LEVEL=info

# Domain
DOMAIN=api.agent-world.com
EMAIL=admin@agent-world.com

# SSL Certificates (Let's Encrypt paths)
SSL_CERT_PATH=/etc/letsencrypt/live/${DOMAIN}/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/${DOMAIN}/privkey.pem

# Rate Limiting (requests per window)
RATE_LIMIT_TIER1=3
RATE_LIMIT_TIER2=5
RATE_LIMIT_TIER3=60

# Audit Log Retention (days)
AUDIT_RETENTION_DAYS=90

# Backup
BACKUP_ENABLED=true
BACKUP_S3_BUCKET=agent-world-backups
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM

# Monitoring
ALERT_EMAIL=ops@agent-world.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Feature Flags
ENABLE_AUTO_SCALING=true
ENABLE_REDIS_CACHE=true
ENABLE_AUDIT_LOG=true
