FROM nginx:alpine

COPY . /usr/share/nginx/html

EXPOSE 8080

# Simple nginx config for SPA
RUN echo 'server { \
    listen 8080; \
    location / { \
        root /usr/share/nginx/html; \
        index index.html; \
        try_files $uri $uri/ /index.html; \
    } \
}' > /etc/nginx/conf.d/default.conf
